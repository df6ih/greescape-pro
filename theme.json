
{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1280px"
    },
    "color": {
      "palette": [
        {
          "slug": "primary",
          "name": "Naturgrün",
          "color": "#2E7D32"
        },
        {
          "slug": "secondary",
          "name": "Hellgrün",
          "color": "#66BB6A"
        },
        {
          "slug": "accent",
          "name": "Gold",
          "color": "#F9A825"
        },
        {
          "slug": "background",
          "name": "Hintergrund",
          "color": "#F8FAF7"
        },
        {
          "slug": "text",
          "name": "Text",
          "color": "#263238"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Inter,sans-serif",
          "name": "Inter",
          "slug": "inter"
        },
        {
          "fontFamily": "Poppins,sans-serif",
          "name": "Poppins",
          "slug": "poppins"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#F8FAF7",
      "text": "#263238"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--poppins)"
        }
      },
      "button": {
        "border": {
          "radius": "40px"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        }
      }
    }
  }
}
